{
    "name": "contract-adapter",
    "version": "1.1.0",
    "description": "A tiny bidirectional DTO adapter for translating backend API contracts into frontend models and back.",
    "bugs": {
        "url": "https://github.com/Reve/contract-adapter/issues"
    },
    "homepage": "https://github.com/Reve/contract-adapter",
    "repository": {
        "url": "git+https://github.com/Reve/contract-adapter.git",
        "type": "git"
    },
    "main": "dist/contract-adapter.js",
    "module": "dist/contract-adapter.es.js",
    "type": "module",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "import": "./dist/contract-adapter.es.js",
            "require": "./dist/contract-adapter.js"
        }
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsup",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
    },
    "keywords": [
        "dto",
        "adapter",
        "contract",
        "api",
        "serializer",
        "deserializer",
        "snake_case",
        "camelCase",
        "case-converter",
        "frontend",
        "backend",
        "json"
    ],
    "files": [
        "dist/",
        "index.d.ts",
        "LICENSE",
        "README.md"
    ],
    "typings": "index.d.ts",
    "author": "Alexandru Gheorghita (Agile Geeks SRL-D)",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@vitest/coverage-v8": "^1.0.0",
        "eslint": "^9.0.0",
        "globals": "^15.0.0",
        "prettier": "^3.0.0",
        "rimraf": "^5.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vitest": "^1.0.0"
    }
}
